new_tab nvim
cd ~/documents/personal/raycast/extensions/send-pr
launch --title "nvim" fish -ic 'nvim; exec fish'

new_tab server
cd ~/documents/personal/raycast/extensions/send-pr
launch --title "server" fish -ic 'npm run dev; exec fish'

new_tab shell
cd ~/documents/personal/raycast/extensions/send-pr
launch --title "shell"
