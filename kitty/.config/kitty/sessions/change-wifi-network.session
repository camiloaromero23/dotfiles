new_tab nvim
cd ~/documents/personal/raycast/extensions/change-wi-fi-network
launch --title "nvim" fish -ic 'nvim; exec fish'

new_tab server
cd ~/documents/personal/raycast/extensions/change-wi-fi-network
launch --title "server" fish -ic 'npm run dev; exec fish'

new_tab shell
cd ~/documents/personal/raycast/extensions/change-wi-fi-network
launch --title "shell"
